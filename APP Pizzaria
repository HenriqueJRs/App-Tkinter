    def get_mensagem_status(self, status, cliente, itens, total):
        """Retorna mensagem apropriada para cada status"""
        mensagens = {
            "Pendente": f"Olá {cliente}! ✅ Seu pedido foi recebido com sucesso e está aguardando preparo.\n\nItens:\n{itens}\n\nTotal: {total}\n\nEm breve iniciaremos o preparo!",
            
            "Em Preparo": f"Olá {cliente}! 👨‍🍳 Boas notícias! Seu pedido:\n{itens}\n\nJá está sendo preparado com todo carinho! Em instantes sairá para entrega.",
            
            "Saiu para Entrega": f"Olá {cliente}! 🛵 Seu pedido:\n{itens}\n\nAcabou de sair para entrega! Fique atento, em breve chegará.",
            
            "Entregue": f"Olá {cliente}! ✅ Seu pedido:\n{itens}\n\nFoi entregue! Obrigado pela preferência! Volte sempre! 🍕",
            
            "Cancelado": f"Olá {cliente}! ❌ Seu pedido:\n{itens}\n\nFoi cancelado. Em caso de dúvidas, entre em contato conosco."
        }
        
        return mensagens.get(status, f"Atualização do pedido: {status}")
    
    def enviar_whatsapp_status(self):
        """Envia WhatsApp para o pedido selecionado"""
        selecao = self.tree_status.selection()
        if not selecao:
            messagebox.showwarning("Aviso", "Selecione um pedido")
            return
        
        valores = self.tree_status.item(selecao)['values']
        pedido_id = valores[0]
        cliente = valores[1]
        telefone = valores[2]
        itens = valores[3]
        total = valores[4] if len(valores) > 4 else "R$ 0,00"
        status = valores[5] if len(valores) > 5 else "Pendente"
        
        # Buscar pedido completo nos dados
        pedido = None
        for v in self.dados["vendas"]:
            if v.get("id") == pedido_id:
                pedido = v
                break
        
        if pedido and "itens" in pedido:
            resumo_itens = "\n".join(pedido["itens"])
        else:
            resumo_itens = itens
        
        mensagem = self.get_mensagem_status(status, cliente, resumo_itens, total)
        
        if telefone:
            telefone_num = re.sub(r'[^0-9]', '', telefone)
            if telefone_num:
                enviar_whatsapp(telefone_num, mensagem)
                messagebox.showinfo("Sucesso", "WhatsApp aberto com mensagem pronta!")
            else:
                messagebox.showwarning("Aviso", "Telefone inválido")
        else:
            messagebox.showwarning("Aviso", "Cliente não possui telefone cadastrado")
    
    def cancelar_pedido(self):
        """Cancela o pedido selecionado"""
        selecao = self.tree_status.selection()
        if not selecao:
            messagebox.showwarning("Aviso", "Selecione um pedido")
            return
        
        valores = self.tree_status.item(selecao)['values']
        pedido_id = valores[0]
        cliente = valores[1]
        telefone = valores[2]
        itens = valores[3]
        total = valores[4]
        status_atual = valores[5]
        
        # Verificar se o pedido já está entregue ou cancelado
        if status_atual in ["Entregue", "Cancelado"]:
            messagebox.showwarning("Aviso", f"Este pedido já está {status_atual.lower()} e não pode ser cancelado.")
            return
        
        # Confirmar cancelamento
        if not messagebox.askyesno("Confirmar Cancelamento", f"Tem certeza que deseja cancelar o pedido de {cliente}?"):
            return
        
        print(f"Cancelando pedido ID: {pedido_id}")  # DEBUG
        
        # Atualizar nos dados
        pedido_atualizado = None
        encontrado = False
        for v in self.dados["vendas"]:
            print(f"Comparando com venda ID: {v.get('id')}")  # DEBUG
            if str(v.get("id")) == str(pedido_id):  # Garantir comparação como string
                v["status"] = "Cancelado"
                v["status_atualizado_em"] = datetime.now().strftime("%d/%m/%Y %H:%M")
                pedido_atualizado = v
                encontrado = True
                print(f"Pedido encontrado e cancelado!")  # DEBUG
                break
        
        if not encontrado:
            print(f"ERRO: Pedido com ID {pedido_id} não encontrado!")  # DEBUG
            messagebox.showerror("Erro", "Pedido não encontrado no banco de dados")
            return
        
        # Salvar no banco de dados
        self.app.db.salvar(self.dados)
        print("Dados salvos com sucesso!")  # DEBUG
        
        # Atualizar o treeview
        self.atualizar_status_tree()
        print("Treeview atualizado!")  # DEBUG
        
        # Perguntar se quer enviar WhatsApp
        if telefone and messagebox.askyesno("Enviar WhatsApp", "Deseja notificar o cliente sobre o cancelamento?"):
            telefone_num = re.sub(r'[^0-9]', '', telefone)
            if telefone_num:
                if pedido_atualizado and "itens" in pedido_atualizado:
                    resumo_itens = "\n".join(pedido_atualizado["itens"])
                else:
                    resumo_itens = itens
                
                mensagem = self.get_mensagem_status("Cancelado", cliente, resumo_itens, total)
                enviar_whatsapp(telefone_num, mensagem)
                messagebox.showinfo("WhatsApp", "WhatsApp aberto com mensagem pronta!")
        
        messagebox.showinfo("Sucesso", "Pedido cancelado com sucesso!")
    
