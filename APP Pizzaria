# =========================

class Database:
    def __init__(self, arquivo=ARQUIVO):
        self.arquivo = arquivo
        self.backup_dir = BACKUP_DIR
        self.export_dir = EXPORT_DIR
        
    def carregar(self):
        """Carrega dados do JSON com estrutura completa"""
        if not os.path.exists(self.arquivo):
            return self.criar_estrutura_inicial()
        
        try:
            with open(self.arquivo, "r", encoding="utf8") as f:
                dados = json.load(f)
            
            estrutura = self.criar_estrutura_inicial()
            for chave in estrutura:
                if chave not in dados:
                    dados[chave] = estrutura[chave]
            
            return dados
            
        except Exception as e:
            messagebox.showerror("Erro", f"Erro ao carregar dados: {e}\n\nArquivo: {self.arquivo}")
            return self.criar_estrutura_inicial()
    
    def criar_estrutura_inicial(self):
        """Cria estrutura inicial dos dados"""
        return {
            "sabores": [],
            "bebidas": [],
            "clientes": [],
            "vendas": [],
            "configuracoes": {
                "ultimo_backup": None,
                "tema": "dark",
                "diretorio_base": BASE_DIR
            }
        }
    
    def salvar(self, dados):
        """Salva dados no JSON"""
        try:
            # Garante que o diretório existe
            os.makedirs(os.path.dirname(self.arquivo), exist_ok=True)
            
            with open(self.arquivo, "w", encoding="utf8") as f:
                json.dump(dados, f, indent=4, ensure_ascii=False)
            return True
        except Exception as e:
            messagebox.showerror("Erro", f"Erro ao salvar: {e}\n\nArquivo: {self.arquivo}")
            return False
    
    def salvar_com_backup(self, dados):
        """Salva com backup automático"""
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        
        try:
            # Garante que o diretório de backup existe
            os.makedirs(self.backup_dir, exist_ok=True)
            
            backup_file = os.path.join(self.backup_dir, f"dados_{timestamp}.json")
            
            with open(backup_file, 'w', encoding='utf8') as f:
                json.dump(dados, f, indent=4, ensure_ascii=False)
            
            self.salvar(dados)
            self.limpar_backups_antigos(10)
            
            dados["configuracoes"]["ultimo_backup"] = timestamp
            return True
            
        except Exception as e:
            messagebox.showerror("Erro", f"Erro no backup: {e}")
            return False
    
    def limpar_backups_antigos(self, manter=10):
        """Mantém apenas os X backups mais recentes"""
        try:
            backups = sorted([f for f in os.listdir(self.backup_dir) 
                             if f.startswith("dados_") and f.endswith(".json")])
            
            while len(backups) > manter:
                os.remove(os.path.join(self.backup_dir, backups.pop(0)))
        except:
            pass  # Ignora erros na limpeza de backups

