        if messagebox.askyesno("Confirmar", "Deseja realmente excluir esta bebida?"):
            idx = self.tree.index(sel)
            del self.dados["bebidas"][idx]
            self.app.db.salvar(self.dados)
            self.atualizar()
            if hasattr(self.app, 'aba_pedidos'):
                self.app.aba_pedidos.atualizar_combobox()
    
    def atualizar(self):
        self.tree.delete(*self.tree.get_children())
        for b in self.dados["bebidas"]:
            self.tree.insert("", "end", values=(b["nome"], formatar_valor(b["preco"])))

