def validar_telefone(telefone):
    """Valida telefone no formato (XX) XXXXX-XXXX ou XXXXXXXXXX"""
    numeros = re.sub(r'[^0-9]', '', telefone)
    if len(numeros) not in [10, 11]:
        return False, "Telefone deve ter 10 ou 11 dígitos"
    return True, numeros

def validar_valor(valor):
    """Valida valor monetário"""
    try:
        valor_float = float(str(valor).replace(',', '.'))
        if valor_float <= 0:
            return False, "Valor deve ser maior que zero"
        if valor_float > 10000:
            return False, "Valor muito alto (máx R$ 10.000)"
        return True, valor_float
    except:
        return False, "Valor inválido"

def validar_data(data):
    """Valida data no formato DD/MM/AAAA"""
    try:
        dia, mes, ano = map(int, data.split('/'))
        datetime(ano, mes, dia)
        return True, data
    except:
        return False, "Data inválida (use DD/MM/AAAA)"

