def enviar_whatsapp(telefone, mensagem):
    """Abre WhatsApp Web com mensagem pré-preenchida e envia automaticamente"""
    try:
        # Remove caracteres não numéricos do telefone
        numeros = re.sub(r'[^0-9]', '', str(telefone))
        
        # Adiciona código do país se necessário
        if len(numeros) == 10 or len(numeros) == 11:
            numeros = "55" + numeros
        
        # Codifica a mensagem para URL
        mensagem_codificada = urllib.parse.quote(mensagem)
        
        # Cria URL do WhatsApp
        url = f"https://wa.me/{numeros}?text={mensagem_codificada}"
        
        # Abre no navegador
        webbrowser.open(url)
        return True, "WhatsApp aberto com sucesso!"
    except Exception as e:
        return False, str(e)

