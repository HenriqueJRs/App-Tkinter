        self.entry_data_ini.grid(row=0, column=1, padx=5)
        self.entry_data_ini.insert(0, (datetime.now() - timedelta(days=30)).strftime("%d/%m/%Y"))
        
        ttk.Label(frame_periodo, text="Data Fim:").grid(row=0, column=2, padx=5)
