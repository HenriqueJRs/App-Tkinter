            tree.delete(selecao)
            self.atualizar_total()
    
    def atualizar_total(self, event=None):
        total_pizzas = 0
        for item in self.tree_pizzas.get_children():
            valores = self.tree_pizzas.item(item)['values']
            subtotal = float(valores[3].replace("R$ ", "").replace(',', '.'))
            total_pizzas += subtotal
        
        total_bebidas = 0
        for item in self.tree_bebidas.get_children():
            valores = self.tree_bebidas.item(item)['values']
            subtotal = float(valores[2].replace("R$ ", "").replace(',', '.'))
            total_bebidas += subtotal
        
        try:
            taxa = float(self.entry_taxa.get().replace(',', '.'))
        except:
            taxa = 0
        
        total_geral = total_pizzas + total_bebidas + taxa
        
        self.label_total.config(text=f"Total: {formatar_valor(total_geral)} (Pizzas: {formatar_valor(total_pizzas)} | Bebidas: {formatar_valor(total_bebidas)} | Taxa: {formatar_valor(taxa)})")
    
    def finalizar_pedido(self):
        cliente = self.entry_cliente.get()
        telefone = self.entry_telefone.get()
        endereco = self.entry_endereco.get()
        
        if not cliente or not endereco:
            messagebox.showerror("Erro", "Cliente e endereço são obrigatórios")
            return
        
        if telefone:
            valido, resultado = validar_telefone(telefone)
            if not valido:
                messagebox.showerror("Erro", resultado)
                return
            telefone = resultado
        
        pizzas_items = self.tree_pizzas.get_children()
        bebidas_items = self.tree_bebidas.get_children()
        
        if not pizzas_items and not bebidas_items:
            messagebox.showerror("Erro", "Adicione pelo menos um item ao pedido (pizza ou bebida)")
            return
        
        try:
            taxa = float(self.entry_taxa.get().replace(',', '.'))
        except:
            taxa = 0
        
        precisa_troco = self.troco_var.get()
        troco_para = 0
        if precisa_troco:
            try:
                troco_para = float(self.entry_troco.get().replace(',', '.'))
            except:
                messagebox.showerror("Erro", "Valor do troco inválido")
                return
        
        # Lista de todos os itens
        itens_lista = []
        total_pizzas = 0
        total_bebidas = 0
        
        # Processa pizzas
        for item in pizzas_items:
            valores = self.tree_pizzas.item(item)['values']
            s1, s2, qtd, subtotal_str = valores
            subtotal = float(subtotal_str.replace("R$ ", "").replace(',', '.'))
            
            if s2 != "-":
                item_desc = f"{qtd}x Pizza 1/2 {s1} / 1/2 {s2}"
            else:
                item_desc = f"{qtd}x Pizza {s1}"
            
            itens_lista.append(item_desc)
            total_pizzas += subtotal
        
        # Processa bebidas
        for item in bebidas_items:
            valores = self.tree_bebidas.item(item)['values']
            bebida, qtd, subtotal_str = valores
            subtotal = float(subtotal_str.replace("R$ ", "").replace(',', '.'))
            
            item_desc = f"{qtd}x {bebida}"
            itens_lista.append(item_desc)
            total_bebidas += subtotal
        
        total_geral = total_pizzas + total_bebidas + taxa
        
        venda = {
            "cliente": cliente,
            "telefone": telefone,
            "endereco": endereco,
            "referencia": self.entry_ref.get(),
            "itens": itens_lista,
            "pizzas": [self.tree_pizzas.item(item)['tags'][0] for item in pizzas_items],
            "bebidas": [self.tree_bebidas.item(item)['tags'][0] for item in bebidas_items],
            "taxa_entrega": taxa,
            "precisa_troco": precisa_troco,
            "troco_para": troco_para if precisa_troco else 0,
            "pagamento": self.combo_pag.get() or "Não informado",
            "total_pizzas": total_pizzas,
            "total_bebidas": total_bebidas,
            "total": total_geral,
            "data": datetime.now().strftime("%d/%m/%Y %H:%M"),
            "id": str(datetime.now().strftime("%Y%m%d%H%M%S")),
            "status": "Pendente",
            "status_atualizado_em": datetime.now().strftime("%d/%m/%Y %H:%M")
        }
        
        self.dados["vendas"].append(venda)
        self.atualizar_cliente(cliente, telefone, endereco, self.entry_ref.get(), total_geral)
        self.app.db.salvar(self.dados)
        
        # Perguntar se quer enviar WhatsApp
        if telefone and messagebox.askyesno("Notificar Cliente", "Deseja notificar o cliente sobre o pedido via WhatsApp?"):
            telefone_num = re.sub(r'[^0-9]', '', telefone)
            if telefone_num:
                mensagem = f"Olá {cliente}! ✅ Seu pedido foi recebido com sucesso e está aguardando preparo.\n\nItens:\n" + "\n".join(itens_lista) + f"\n\nTotal: {formatar_valor(total_geral)}\n\nEm breve iniciaremos o preparo!"
                enviar_whatsapp(telefone_num, mensagem)
                messagebox.showinfo("WhatsApp", "WhatsApp aberto com mensagem pronta!")
        
        messagebox.showinfo("Sucesso", "Pedido finalizado com sucesso!")
        self.novo_pedido()
        if hasattr(self.app, 'aba_vendas'):
            self.app.aba_vendas.atualizar()
        
        self.atualizar_status_tree()
    
    def atualizar_cliente(self, nome, telefone, endereco, referencia, valor_compra):
        if not telefone:
            return
            
        for cliente in self.dados["clientes"]:
            if cliente["telefone"] == telefone:
                cliente["total_gasto"] = cliente.get("total_gasto", 0) + valor_compra
                cliente["ultima_compra"] = datetime.now().strftime("%d/%m/%Y %H:%M")
                return
        
        self.dados["clientes"].append({
            "nome": nome,
            "telefone": telefone,
            "endereco": endereco,
            "referencia": referencia,
            "total_gasto": valor_compra,
            "ultima_compra": datetime.now().strftime("%d/%m/%Y %H:%M"),
            "data_cadastro": datetime.now().strftime("%d/%m/%Y")
        })
    
    def novo_pedido(self):
        self.entry_cliente.delete(0, tk.END)
        self.entry_telefone.delete(0, tk.END)
        self.entry_endereco.delete(0, tk.END)
        self.entry_ref.delete(0, tk.END)
        self.entry_taxa.delete(0, tk.END)
        self.entry_taxa.insert(0, "0")
        self.troco_var.set(False)
        self.toggle_troco()
        self.combo_pag.set("")
        
        for item in self.tree_pizzas.get_children():
            self.tree_pizzas.delete(item)
        
        for item in self.tree_bebidas.get_children():
            self.tree_bebidas.delete(item)
        
        self.label_total.config(text="Total: R$ 0,00")
    
    def atualizar_combobox(self):
        sabores = [s["nome"] for s in self.dados["sabores"]]
        self.combo_sabor1["values"] = sabores
        self.combo_sabor2["values"] = sabores
        
        bebidas = [b["nome"] for b in self.dados["bebidas"]]
        self.combo_bebida["values"] = bebidas
    
    def filtrar_status(self):
        """Filtra os pedidos no treeview de status"""
        status_filtro = self.combo_status_filtro.get()
        cliente_filtro = self.entry_cliente_filtro.get().lower()
        
        self.tree_status.delete(*self.tree_status.get_children())
        
        for v in self.dados["vendas"]:
            # Aplicar filtros
            if status_filtro != "Todos" and v.get("status", "Pendente") != status_filtro:
                continue
            
            if cliente_filtro and cliente_filtro not in v["cliente"].lower():
                continue
            
            # Formatar itens para exibição
            if "itens" in v:
                itens_str = "\n".join(v["itens"][:3])
                if len(v["itens"]) > 3:
                    itens_str += f"\n... +{len(v['itens'])-3} itens"
            elif "pizzas" in v:
                itens_str = "\n".join(v["pizzas"][:3])
                if len(v["pizzas"]) > 3:
                    itens_str += f"\n... +{len(v['pizzas'])-3} pizzas"
            else:
                itens_str = "Item não especificado"
            
            # Garantir que o status seja mostrado corretamente
            status_atual = v.get("status", "Pendente")
            print(f"Inserindo pedido {v.get('id')} com status: {status_atual}")  # DEBUG
            
            self.tree_status.insert("", "end", values=(
                v.get("id", ""),
                v["cliente"],
                formatar_telefone(v.get("telefone", "")),
                itens_str,
                formatar_valor(v["total"]),
                status_atual,  # Usar a variável local
                v["data"]
            ))
    
    def atualizar_status_tree(self):
        """Atualiza o treeview de status"""
        self.filtrar_status()

