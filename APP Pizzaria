        self.atualizar_status_backup()
        
    def configurar_atalhos(self):
        self.root.bind('<Control-n>', lambda e: self.aba_pedidos.novo_pedido())
        self.root.bind('<Control-s>', lambda e: self.fazer_backup())
        self.root.bind('<Control-f>', lambda e: self.aba_clientes.buscar())
        self.root.bind('<F1>', lambda e: self.mostrar_ajuda())
        
    def fazer_backup(self):
        if self.db.salvar_com_backup(self.dados):
            messagebox.showinfo("Sucesso", f"Backup realizado com sucesso!\nPasta: {BACKUP_DIR}")
            self.atualizar_status_backup()
        else:
            messagebox.showerror("Erro", "Falha ao fazer backup")
    
    def fazer_backup_automatico(self):
        """Faz backup automático ao iniciar"""
        try:
            self.db.salvar_com_backup(self.dados)
            self.atualizar_status_backup()
        except:
            pass
    
    def atualizar_status_backup(self):
        ultimo = self.dados["configuracoes"].get("ultimo_backup")
        if ultimo:
            self.backup_label.config(text=f"📦 Último backup: {ultimo}")
    
    def atualizar_todas_abas(self):
        if hasattr(self, 'aba_sabores'):
            self.aba_sabores.atualizar()
        if hasattr(self, 'aba_bebidas'):
            self.aba_bebidas.atualizar()
        if hasattr(self, 'aba_clientes'):
            self.aba_clientes.atualizar()
        if hasattr(self, 'aba_vendas'):
            self.aba_vendas.atualizar()
        if hasattr(self, 'aba_pedidos'):
            self.aba_pedidos.atualizar_status_tree()
    
    @lru_cache(maxsize=128)
    def preco_sabor(self, nome):
        for s in self.dados["sabores"]:
            if s["nome"] == nome:
                return s["preco"]
        return 0
    
    def preco_bebida(self, nome):
        for b in self.dados["bebidas"]:
            if b["nome"] == nome:
                return b["preco"]
        return 0
    
    def mostrar_ajuda(self):
