        texto_msg = tk.Text(janela_msg, height=15, width=60, bg="#3a3a3a", fg="white")
        texto_msg.pack(pady=10, padx=10)
        
        # Sugestões de mensagens
        frame_sugestoes = ttk.Frame(janela_msg)
        frame_sugestoes.pack(pady=5)
        
        def inserir_sugestao(sugestao):
            texto_msg.insert(tk.END, sugestao)
        
        ttk.Button(frame_sugestoes, text="Promoção", 
                  command=lambda: inserir_sugestao(f"Olá {nome}! 🍕 Temos promoções especiais hoje! Pizza grande a partir de R$ 35,00. Faça seu pedido!")).pack(side=tk.LEFT, padx=2)
        
        ttk.Button(frame_sugestoes, text="Fidelidade", 
