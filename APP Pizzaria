    def adicionar_pizza(self):
        s1 = self.combo_sabor1.get()
        if not s1:
            messagebox.showerror("Erro", "Selecione o sabor 1")
            return
        
        try:
            qtd = int(self.entry_qtd_pizza.get())
            if qtd <= 0:
                raise ValueError
        except:
            messagebox.showerror("Erro", "Quantidade inválida")
            return
        
        s2 = self.combo_sabor2.get()
        p1 = self.app.preco_sabor(s1)
        p2 = self.app.preco_sabor(s2) if s2 else 0
        preco = max(p1, p2)
        subtotal = preco * qtd
        
        if s2:
            descricao = f"{qtd}x Pizza 1/2 {s1} / 1/2 {s2}"
        else:
            descricao = f"{qtd}x Pizza {s1}"
        
        self.tree_pizzas.insert("", "end", values=(s1, s2 if s2 else "-", qtd, formatar_valor(subtotal)), 
                               tags=(descricao,))
        
        self.combo_sabor1.set("")
        self.combo_sabor2.set("")
        self.entry_qtd_pizza.delete(0, tk.END)
        self.entry_qtd_pizza.insert(0, "1")
        
        self.atualizar_total()
    
    def adicionar_bebida(self):
        bebida = self.combo_bebida.get()
        if not bebida:
            messagebox.showerror("Erro", "Selecione uma bebida")
            return
        
        try:
            qtd = int(self.entry_qtd_bebida.get())
            if qtd <= 0:
                raise ValueError
        except:
            messagebox.showerror("Erro", "Quantidade inválida")
            return
        
        preco = self.app.preco_bebida(bebida)
        subtotal = preco * qtd
        
        self.tree_bebidas.insert("", "end", values=(bebida, qtd, formatar_valor(subtotal)),
                                tags=(f"{qtd}x {bebida}",))
        
        self.combo_bebida.set("")
        self.entry_qtd_bebida.delete(0, tk.END)
        self.entry_qtd_bebida.insert(0, "1")
        
        self.atualizar_total()
    
    def remover_item(self, tree):
