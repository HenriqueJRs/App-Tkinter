        hsb.grid(row=1, column=0, sticky="ew")
        
        frame_tree.grid_rowconfigure(0, weight=1)
        frame_tree.grid_columnconfigure(0, weight=1)
        
        self.label_total = ttk.Label(self, text="Total do período: R$ 0,00", 
                                     font=("Segoe UI", 12, "bold"))
        self.label_total.place(x=20, y=630)
        
        self.atualizar()
    
    def filtrar(self):
        data_ini = self.entry_data_ini.get()
        data_fim = self.entry_data_fim.get()
        
        if not validar_data(data_ini)[0] or not validar_data(data_fim)[0]:
            messagebox.showerror("Erro", "Datas inválidas")
            return
        
        self.tree.delete(*self.tree.get_children())
        total_periodo = 0
        
        for v in self.dados["vendas"]:
            data_venda = datetime.strptime(v["data"].split()[0], "%d/%m/%Y")
            data_ini_dt = datetime.strptime(data_ini, "%d/%m/%Y")
            data_fim_dt = datetime.strptime(data_fim, "%d/%m/%Y")
            
            if data_ini_dt <= data_venda <= data_fim_dt:
                # Compatibilidade com formato antigo e novo
                if "itens" in v:
                    itens_str = "\n".join(v["itens"])
                elif "pizzas" in v:
                    itens_str = "\n".join(v["pizzas"])
                elif "pizza" in v:
                    itens_str = v["pizza"]
                else:
                    itens_str = "Item não especificado"
                
                pagamento_info = v["pagamento"]
                if v.get("precisa_troco", False) and v.get("troco_para", 0) > 0:
                    pagamento_info += f"\n(Troco p/ R$ {v['troco_para']:.2f})"
                
                self.tree.insert("", "end", values=(
                    v["data"],
                    v["cliente"],
                    formatar_telefone(v.get("telefone", "")),
                    itens_str,
                    pagamento_info,
                    formatar_valor(v["total"]),
                    v.get("status", "Pendente")
                ))
                total_periodo += v["total"]
        
        self.label_total.config(text=f"Total do período: {formatar_valor(total_periodo)}")
    
    def atualizar(self):
        self.entry_data_ini.delete(0, tk.END)
        self.entry_data_ini.insert(0, (datetime.now() - timedelta(days=30)).strftime("%d/%m/%Y"))
        self.entry_data_fim.delete(0, tk.END)
        self.entry_data_fim.insert(0, datetime.now().strftime("%d/%m/%Y"))
        self.filtrar()
    
    def exportar(self):
        if not self.dados["vendas"]:
            messagebox.showwarning("Aviso", "Nenhuma venda para exportar")
            return
        
        vendas_filtradas = []
        data_ini = datetime.strptime(self.entry_data_ini.get(), "%d/%m/%Y")
        data_fim = datetime.strptime(self.entry_data_fim.get(), "%d/%m/%Y")
        
        for v in self.dados["vendas"]:
            data_venda = datetime.strptime(v["data"].split()[0], "%d/%m/%Y")
            if data_ini <= data_venda <= data_fim:
                vendas_filtradas.append(v)
        
        if not vendas_filtradas:
            messagebox.showwarning("Aviso", "Nenhuma venda no período selecionado")
            return
        
        sucesso, caminho = exportar_para_excel(vendas_filtradas, "vendas")
        if sucesso:
            messagebox.showinfo("Sucesso", f"Vendas exportadas para:\n{caminho}")
        else:
            messagebox.showerror("Erro", f"Falha na exportação: {caminho}")

