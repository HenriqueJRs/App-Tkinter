        self.entry_data_fim.insert(0, datetime.now().strftime("%d/%m/%Y"))
        
        ttk.Button(frame_periodo, text="📊 Gerar Relatórios", 
                  command=self.gerar_relatorios).grid(row=1, column=0, columnspan=4, pady=10)
        
        frame_resumo = ttk.LabelFrame(self, text="Resumo do Período", padding=10)
        frame_resumo.place(x=20, y=140, width=500, height=200)
        
        self.text_resumo = tk.Text(frame_resumo, height=8, width=60, bg="#3a3a3a", fg="white")
        self.text_resumo.pack(fill="both", expand=True)
        
        frame_top = ttk.LabelFrame(self, text="Produtos Mais Vendidos", padding=10)
        frame_top.place(x=550, y=20, width=400, height=320)
        
        self.tree_top = ttk.Treeview(frame_top, columns=("Produto", "Quantidade", "Tipo"), 
                                     show="headings", height=12)
        self.tree_top.heading("Produto", text="Produto")
        self.tree_top.heading("Quantidade", text="Quantidade")
        self.tree_top.heading("Tipo", text="Tipo")
        
        self.tree_top.column("Produto", width=150)
        self.tree_top.column("Quantidade", width=100)
        self.tree_top.column("Tipo", width=100)
        
        self.tree_top.pack(fill="both", expand=True)
        
        ttk.Button(self, text="📥 Exportar Resumo", command=self.exportar_resumo).place(x=20, y=350)
        ttk.Button(self, text="📥 Exportar Top Produtos", command=self.exportar_top).place(x=150, y=350)
        
        self.gerar_relatorios()
    
    def gerar_relatorios(self):
        data_ini = self.entry_data_ini.get()
        data_fim = self.entry_data_fim.get()
        
        if not validar_data(data_ini)[0] or not validar_data(data_fim)[0]:
            messagebox.showerror("Erro", "Datas inválidas")
            return
        
        data_ini_dt = datetime.strptime(data_ini, "%d/%m/%Y")
        data_fim_dt = datetime.strptime(data_fim, "%d/%m/%Y")
        
        vendas_periodo = []
        for v in self.dados["vendas"]:
            data_venda = datetime.strptime(v["data"].split()[0], "%d/%m/%Y")
            if data_ini_dt <= data_venda <= data_fim_dt:
                vendas_periodo.append(v)
        
        if not vendas_periodo:
            self.text_resumo.delete(1.0, tk.END)
            self.text_resumo.insert(1.0, "Nenhuma venda no período selecionado.")
            return
        
        total_vendas = len(vendas_periodo)
        total_faturado = sum(v["total"] for v in vendas_periodo)
        media_por_venda = total_faturado / total_vendas if total_vendas > 0 else 0
        total_taxas = sum(v.get("taxa_entrega", 0) for v in vendas_periodo)
        total_pizzas = sum(v.get("total_pizzas", 0) for v in vendas_periodo)
        total_bebidas = sum(v.get("total_bebidas", 0) for v in vendas_periodo)
        
        pagamentos = {}
        for v in vendas_periodo:
            pag = v["pagamento"].split()[0] if " " in v["pagamento"] else v["pagamento"]
            pagamentos[pag] = pagamentos.get(pag, 0) + 1
        
        # Estatísticas por status
        status_count = {}
        for v in vendas_periodo:
            status = v.get("status", "Pendente")
            status_count[status] = status_count.get(status, 0) + 1
        
        # Contagem de produtos
        produtos_count = {}
        for v in vendas_periodo:
            itens = v.get("itens", [])
            if not itens and "pizzas" in v:
                itens = v["pizzas"]
            
            for item in itens:
                import re
                match = re.match(r'(\d+)x\s*(.+)', item)
                if match:
                    qtd = int(match.group(1))
                    produto = match.group(2)
                    
                    if "Pizza" in produto or "pizza" in produto:
                        tipo = "Pizza"
                        if "1/2" in produto:
                            sabores = re.findall(r'1/2\s*([^/]+)', produto)
                            for s in sabores:
                                s = s.strip()
                                key = f"{s} (Pizza)"
                                produtos_count[key] = produtos_count.get(key, 0) + qtd
                        else:
                            nome = produto.replace("Pizza ", "").replace("pizza ", "")
                            key = f"{nome} (Pizza)"
                            produtos_count[key] = produtos_count.get(key, 0) + qtd
                    else:
                        key = f"{produto} (Bebida)"
                        produtos_count[key] = produtos_count.get(key, 0) + qtd
        
        self.text_resumo.delete(1.0, tk.END)
        resumo = f"""
📊 RELATÓRIO DO PERÍODO: {data_ini} a {data_fim}
{'='*50}

📈 Estatísticas Gerais:
   • Total de Vendas: {total_vendas}
   • Total Faturado: {formatar_valor(total_faturado)}
   • Total em Pizzas: {formatar_valor(total_pizzas)}
   • Total em Bebidas: {formatar_valor(total_bebidas)}
   • Total em Taxas: {formatar_valor(total_taxas)}
   • Média por Venda: {formatar_valor(media_por_venda)}

📊 Status dos Pedidos:
"""
        for status, qtd in status_count.items():
            percentual = (qtd / total_vendas) * 100
            resumo += f"   • {status}: {qtd} pedidos ({percentual:.1f}%)\n"

        resumo += f"""
💳 Formas de Pagamento:
"""
        for pag, qtd in pagamentos.items():
            percentual = (qtd / total_vendas) * 100
            resumo += f"   • {pag}: {qtd} vendas ({percentual:.1f}%)\n"
        
        self.text_resumo.insert(1.0, resumo)
        
        self.tree_top.delete(*self.tree_top.get_children())
        produtos_ordenados = sorted(produtos_count.items(), key=lambda x: x[1], reverse=True)[:10]
        
        for produto, qtd in produtos_ordenados:
            tipo = "Pizza" if "(Pizza)" in produto else "Bebida"
            nome = produto.replace(" (Pizza)", "").replace(" (Bebida)", "")
            self.tree_top.insert("", "end", values=(
                nome, qtd, tipo
            ))
    
    def exportar_resumo(self):
        resumo = self.text_resumo.get(1.0, tk.END)
        
        try:
            caminho = os.path.join(EXPORT_DIR, f"resumo_{datetime.now():%Y%m%d_%H%M}.txt")
            with open(caminho, 'w', encoding='utf-8') as f:
                f.write(resumo)
            messagebox.showinfo("Sucesso", f"Resumo exportado para:\n{caminho}")
        except Exception as e:
            messagebox.showerror("Erro", f"Falha ao exportar: {e}")
    
    def exportar_top(self):
        dados_top = []
        for item in self.tree_top.get_children():
            valores = self.tree_top.item(item)['values']
            dados_top.append({
                "Produto": valores[0],
                "Quantidade": valores[1],
                "Tipo": valores[2]
            })
        
        if not dados_top:
            messagebox.showwarning("Aviso", "Nenhum dado para exportar")
            return
        
        sucesso, caminho = exportar_para_excel(dados_top, "top_produtos")
        if sucesso:
            messagebox.showinfo("Sucesso", f"Top produtos exportados para:\n{caminho}")
        else:
            messagebox.showerror("Erro", f"Falha na exportação: {caminho}")

