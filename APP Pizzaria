        self.tree.heading("Valor", text="Valor")
        self.tree.place(x=20, y=120, width=400, height=500)

        ttk.Button(self, text="➕ Adicionar", command=self.adicionar).place(x=20, y=630)
        ttk.Button(self, text="✏️ Editar", command=self.editar).place(x=120, y=630)
        ttk.Button(self, text="🗑️ Excluir", command=self.excluir).place(x=200, y=630)
        
        self.atualizar()
    
    def adicionar(self):
        nome = self.entry_nome.get()
        if not nome:
            messagebox.showerror("Erro", "Nome do sabor é obrigatório")
            return
        
        valido, resultado = validar_valor(self.entry_valor.get())
        if not valido:
            messagebox.showerror("Erro", resultado)
            return
        
        self.dados["sabores"].append({"nome": nome, "preco": resultado})
        self.app.db.salvar(self.dados)
        
        self.entry_nome.delete(0, tk.END)
        self.entry_valor.delete(0, tk.END)
        self.atualizar()
        if hasattr(self.app, 'aba_pedidos'):
            self.app.aba_pedidos.atualizar_combobox()
        
        self.app.preco_sabor.cache_clear()
    
    def editar(self):
        sel = self.tree.selection()
        if not sel:
            messagebox.showwarning("Aviso", "Selecione um sabor")
            return
        
        idx = self.tree.index(sel)
        sabor = self.dados["sabores"][idx]
        
        root = self.winfo_toplevel()
        root.lift()
        root.focus_force()
        
        nome = simpledialog.askstring("Editar Sabor", "Nome:", initialvalue=sabor["nome"], parent=self)
        if nome is None:
            return
        
        if not nome:
            messagebox.showerror("Erro", "Nome não pode ser vazio")
            return
        
        root.lift()
        root.focus_force()
        
        valor_str = simpledialog.askstring("Editar Sabor", "Valor (R$):", 
                                          initialvalue=str(sabor["preco"]).replace('.', ','), 
                                          parent=self)
        if valor_str is None:
            return
        
        valido, valor = validar_valor(valor_str)
        if not valido:
            messagebox.showerror("Erro", valor)
            return
        
        self.dados["sabores"][idx] = {"nome": nome, "preco": valor}
        self.app.db.salvar(self.dados)
        self.atualizar()
        if hasattr(self.app, 'aba_pedidos'):
            self.app.aba_pedidos.atualizar_combobox()
        self.app.preco_sabor.cache_clear()
    
    def excluir(self):
        sel = self.tree.selection()
        if not sel:
            messagebox.showwarning("Aviso", "Selecione um sabor")
            return
        
        if messagebox.askyesno("Confirmar", "Deseja realmente excluir este sabor?"):
            idx = self.tree.index(sel)
            del self.dados["sabores"][idx]
            self.app.db.salvar(self.dados)
            self.atualizar()
            if hasattr(self.app, 'aba_pedidos'):
                self.app.aba_pedidos.atualizar_combobox()
            self.app.preco_sabor.cache_clear()
    
    def atualizar(self):
        self.tree.delete(*self.tree.get_children())
        for s in self.dados["sabores"]:
            self.tree.insert("", "end", values=(s["nome"], formatar_valor(s["preco"])))

