def get_base_path():
    """Retorna o caminho base correto (para executável ou script)"""
    if getattr(sys, 'frozen', False):
        # Se for executável
        return os.path.dirname(sys.executable)
    else:
        # Se for script
        return os.path.dirname(os.path.abspath(__file__))

def get_writable_path():
    """Retorna um caminho onde temos permissão de escrita"""
    try:
        base_path = get_base_path()
        # Tenta criar um arquivo de teste
        test_file = os.path.join(base_path, 'test_permission.tmp')
        with open(test_file, 'w') as f:
            f.write('test')
        os.remove(test_file)
        # Se conseguiu, usa o diretório base
        return base_path
    except (PermissionError, OSError):
        # Se não tem permissão, usa AppData
        appdata = os.environ.get('APPDATA', os.path.expanduser('~'))
        app_dir = os.path.join(appdata, 'PizzariaSystem')
        os.makedirs(app_dir, exist_ok=True)
        return app_dir

